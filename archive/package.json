{
  "name": "voca",
  "version": "1.0.0",
  "description": "Task management assistant powered by Gemini",
  "type": "module",
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "start": "tsx src/index.ts",
    "dev": "tsx watch src/index.ts",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.ts\" \"src/tests/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"src/tests/**/*.ts\"",
    "test": "pnpm test:unit && pnpm test:e2e && pnpm test:playwright",
    "vr": "vitest run",
    "test:watch": "vitest watch src/tests/unit src/tests/e2e",
    "test:unit": "vitest run src/tests/unit",
    "test:e2e": "vitest run src/tests/e2e",
    "test:playwright": "CI=true npx playwright test"
  },
  "keywords": [
    "task-management",
    "ai",
    "gemini",
    "cli",
    "linear"
  ],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@eslint/js": "^9.21.0",
    "@playwright/test": "^1.52.0",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.13.9",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^8.26.0",
    "@typescript-eslint/parser": "^8.26.0",
    "eslint": "^9.21.0",
    "eslint-plugin-unused-imports": "^4.1.4",
    "jest": "^29.7.0",
    "prettier": "^3.5.3",
    "ts-jest": "^29.2.6",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.26.0",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^3.1.2"
  },
  "dependencies": {
    "@google/genai": "^0.12.0",
    "@langchain/google-genai": "^0.2.3",
    "@langchain/langgraph": "^0.2.64",
    "@linear/sdk": "^38.0.0",
    "@types/dotenv": "^8.2.3",
    "@types/ioredis": "^5.0.0",
    "chalk": "^5.4.1",
    "dotenv": "^16.5.0",
    "fast-json-patch": "^3.1.1",
    "immer": "^10.1.1",
    "ioredis": "^5.6.1",
    "uuid": "^11.1.0",
    "yargs": "^17.7.2",
    "zod": "^3.24.2"
  }
}
